{
  "name": "gimnasio",
  "version": "2.0.0",
  "description": "Sistema de registro y control de acceso para gimnasio — Cloudflare Workers",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:init": "wrangler d1 execute gimnasio --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute gimnasio --file=src/db/seed.sql",
    "db:init:local": "wrangler d1 execute gimnasio --local --file=src/db/schema.sql",
    "db:seed:local": "wrangler d1 execute gimnasio --local --file=src/db/seed.sql"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.13",
    "ejs": "^3.1.10",
    "hono": "^4.7.11",
    "jose": "^5.10.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.5",
    "wrangler": "^4.0.0"
  }
}
