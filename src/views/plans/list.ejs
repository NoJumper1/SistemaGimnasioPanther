<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Planes de membresía</h1>
  <a href="/plans/new" class="btn btn-primary">+ Nuevo plan</a>
</div>

<table class="table align-middle">
  <thead>
    <tr><th>Nombre</th><th>Duración (días)</th><th>Precio</th><th>Activo</th><th></th></tr>
  </thead>
  <tbody>
    <% plans.forEach(plan => { %>
      <tr>
        <td><%= plan.name %></td>
        <td><%= plan.duration_days %></td>
        <td>$<%= plan.price %></td>
        <td><%= plan.active ? 'Sí' : 'No' %></td>
        <td>
          <a href="/plans/<%= plan.id %>/edit" class="btn btn-sm btn-outline-primary">Editar</a>
          <form action="/plans/<%= plan.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('¿Desactivar este plan?');">
            <button class="btn btn-sm btn-outline-danger" type="submit">Desactivar</button>
          </form>
        </td>
      </tr>
    <% }) %>
    <% if (plans.length === 0) { %>
      <tr><td colspan="5" class="text-muted text-center">No hay planes creados.</td></tr>
    <% } %>
  </tbody>
</table>
