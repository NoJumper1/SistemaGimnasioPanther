<h1 class="mb-4"><%= plan ? 'Editar plan' : 'Nuevo plan' %></h1>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<form method="POST" action="<%= plan ? `/plans/${plan.id}` : '/plans' %>" class="row g-3">
  <div class="col-md-6">
    <label class="form-label">Nombre *</label>
    <input type="text" name="name" class="form-control" value="<%= plan ? plan.name : '' %>" required>
  </div>
  <div class="col-md-3">
    <label class="form-label">Duración (días) *</label>
    <input type="number" name="duration_days" class="form-control" value="<%= plan ? plan.duration_days : '' %>" required>
  </div>
  <div class="col-md-3">
    <label class="form-label">Precio</label>
    <input type="number" step="0.01" name="price" class="form-control" value="<%= plan ? plan.price : 0 %>">
  </div>
  <% if (plan) { %>
    <div class="col-12">
      <div class="form-check">
        <input type="checkbox" name="active" class="form-check-input" id="active" <%= plan.active ? 'checked' : '' %>>
        <label class="form-check-label" for="active">Activo</label>
      </div>
    </div>
  <% } %>
  <div class="col-12">
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="/plans" class="btn btn-outline-secondary">Cancelar</a>
  </div>
</form>
