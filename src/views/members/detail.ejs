<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h1 class="mb-1"><%= member.full_name %></h1>
    <span class="badge <%= STATUS_BADGE_CLASSES[status] %>"><%= STATUS_LABELS[status] %></span>
    <% if (endDate) { %><span class="text-muted ms-2">vence el <%= endDate %></span><% } %>
    <% if (!member.active) { %><span class="badge bg-dark ms-2">Baja</span><% } %>
  </div>
  <div>
    <a href="/members/<%= member.id %>/edit" class="btn btn-outline-secondary">Editar datos</a>
    <% if (member.active) { %>
      <form action="/members/<%= member.id %>/deactivate" method="POST" class="d-inline">
        <button class="btn btn-outline-danger" type="submit">Dar de baja</button>
      </form>
    <% } else { %>
      <form action="/members/<%= member.id %>/activate" method="POST" class="d-inline">
        <button class="btn btn-outline-success" type="submit">Reactivar</button>
      </form>
    <% } %>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-6">
    <p><strong>Email:</strong> <%= member.email || '—' %></p>
    <p><strong>Teléfono:</strong> <%= member.phone || '—' %></p>
    <p><strong>Inscripción:</strong> <%= member.join_date %></p>
    <p><strong>Notas:</strong> <%= member.notes || '—' %></p>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">Registrar nuevo pago</div>
  <div class="card-body">
    <form method="POST" action="/members/<%= member.id %>/subscriptions" class="row g-3">
      <div class="col-md-4">
        <label class="form-label">Plan</label>
        <select name="plan_id" id="plan_id" class="form-select">
          <option value="">Personalizado</option>
          <% plans.forEach(plan => { %>
            <option value="<%= plan.id %>" data-duration="<%= plan.duration_days %>" data-price="<%= plan.price %>">
              <%= plan.name %> (<%= plan.duration_days %> días — $<%= plan.price %>)
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Fecha de inicio</label>
        <input type="date" name="start_date" id="start_date" class="form-control" value="<%= today %>" required>
      </div>
      <div class="col-md-3">
        <label class="form-label">Fecha de fin</label>
        <input type="date" name="end_date" id="end_date" class="form-control" required>
      </div>
      <div class="col-md-2">
        <label class="form-label">Monto</label>
        <input type="number" step="0.01" name="amount" id="amount" class="form-control" value="0">
      </div>
      <div class="col-md-4">
        <label class="form-label">Método de pago</label>
        <input type="text" name="payment_method" class="form-control" placeholder="Efectivo, transferencia...">
      </div>
      <div class="col-md-4">
        <label class="form-label">Notas</label>
        <input type="text" name="notes" class="form-control">
      </div>
      <div class="col-12">
        <button type="submit" class="btn btn-primary">Registrar pago</button>
      </div>
    </form>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">Historial de pagos</div>
  <div class="card-body p-0">
    <table class="table mb-0">
      <thead>
        <tr><th>Inicio</th><th>Fin</th><th>Monto</th><th>Método</th><th>Registrado</th></tr>
      </thead>
      <tbody>
        <% subscriptions.forEach(sub => { %>
          <tr>
            <td><%= sub.start_date %></td>
            <td><%= sub.end_date %></td>
            <td>$<%= sub.amount %></td>
            <td><%= sub.payment_method || '—' %></td>
            <td><%= sub.payment_date %></td>
          </tr>
        <% }) %>
        <% if (subscriptions.length === 0) { %>
          <tr><td colspan="5" class="text-muted text-center">Sin pagos registrados.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div class="card">
  <div class="card-header">Check-ins recientes</div>
  <div class="card-body p-0">
    <table class="table mb-0">
      <thead><tr><th>Fecha</th><th>Resultado</th><th>Motivo</th></tr></thead>
      <tbody>
        <% recentCheckins.forEach(c => { %>
          <tr>
            <td><%= c.timestamp %></td>
            <td><span class="badge <%= c.result === 'allowed' ? 'bg-success' : 'bg-danger' %>"><%= c.result === 'allowed' ? 'Permitido' : 'Denegado' %></span></td>
            <td><%= c.reason || '—' %></td>
          </tr>
        <% }) %>
        <% if (recentCheckins.length === 0) { %>
          <tr><td colspan="3" class="text-muted text-center">Sin check-ins registrados.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
  // Autocompleta fecha de fin y monto al elegir un plan
  const planSelect = document.getElementById('plan_id');
  const startInput = document.getElementById('start_date');
  const endInput = document.getElementById('end_date');
  const amountInput = document.getElementById('amount');

  function applyPlan() {
    const opt = planSelect.options[planSelect.selectedIndex];
    const duration = parseInt(opt.dataset.duration, 10);
    if (!duration) return;
    const start = startInput.value ? new Date(startInput.value) : new Date();
    const end = new Date(start);
    end.setDate(end.getDate() + duration);
    endInput.value = end.toISOString().slice(0, 10);
    if (opt.dataset.price) amountInput.value = opt.dataset.price;
  }

  planSelect.addEventListener('change', applyPlan);
  startInput.addEventListener('change', applyPlan);
</script>
