<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Acceso · Panther Zone Gym</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/screensaver.css">
</head>
<body class="ss-body">

  <!-- ENCABEZADO -->
  <header class="ss-header">
    <div class="ss-header-left">
      <a href="/" class="ss-close-btn" title="Volver al Dashboard">
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
          <path d="M3 7h8M3 7l3-3M3 7l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Dashboard
      </a>
      <div class="ss-brand">
        <img src="/img/logo.png" alt="Logo" class="ss-logo">
        <span class="ss-gym-name">Panther <span class="ss-accent">Zone</span> Gym</span>
      </div>
    </div>
    <div class="ss-datetime">
      <div id="ss-time" class="ss-time">--:--:--</div>
      <div id="ss-date" class="ss-date">---</div>
    </div>
  </header>

  <!-- BARRA "ESTÁ SONANDO" -->
  <div class="ss-np-bar" id="ss-np-bar">
    <div class="ss-np-icon">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
        <circle cx="9" cy="18" r="3" fill="currentColor"/>
        <circle cx="19" cy="16" r="3" fill="currentColor"/>
        <path d="M12 18V6l10-2v12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <span class="ss-np-label">Está sonando</span>
    <div class="ss-np-sep"></div>
    <img id="np-album" class="ss-np-album" src="" alt="" style="display:none">
    <span class="ss-np-song" id="np-song">—</span>
    <span class="ss-np-dot">·</span>
    <span class="ss-np-artist" id="np-artist">—</span>
    <div class="ss-np-wave">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
  </div>

  <!-- CONTENIDO PRINCIPAL: 3 columnas -->
  <main class="ss-main">

    <!-- COLUMNA IZQUIERDA: bienvenida + frase -->
    <div class="ss-col-welcome">
      <div class="ss-welcome-block">
        <div class="ss-welcome-label">Bienvenido/a a</div>
        <div class="ss-welcome-name">Panther <span class="ss-accent">Zone</span> Gym</div>
      </div>
      <div class="ss-quote-block">
        <div class="ss-quote-mark">"</div>
        <div id="ss-quote" class="ss-quote"></div>
      </div>
      <div class="ss-demo-badge">● MODO DEMO · Toca el lector para simular</div>
      <a href="/screensaver/carousel-admin" class="ss-carousel-link">⚙ Gestionar carrusel</a>
    </div>

    <!-- COLUMNA CENTRAL: lector de huella + estado -->
    <div class="ss-col-reader">

      <div id="fp-reader" class="fp-reader" onclick="triggerScan()" title="Clic para simular">
        <svg class="fp-svg" viewBox="0 0 220 285" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <clipPath id="fp-clip">
              <rect x="28" y="22" width="164" height="190" rx="14"/>
            </clipPath>
            <linearGradient id="scan-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%"   stop-color="#38bdf8" stop-opacity="0"/>
              <stop offset="40%"  stop-color="#38bdf8" stop-opacity="0.55"/>
              <stop offset="60%"  stop-color="#38bdf8" stop-opacity="0.55"/>
              <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
            </linearGradient>
            <radialGradient id="device-grad" cx="50%" cy="30%" r="70%">
              <stop offset="0%"   stop-color="#252540"/>
              <stop offset="100%" stop-color="#111120"/>
            </radialGradient>
          </defs>
          <rect x="8" y="8" width="204" height="269" rx="28" fill="url(#device-grad)" stroke="rgba(255,255,255,0.08)" stroke-width="1.5"/>
          <rect x="28" y="22" width="164" height="190" rx="14" class="fp-sensing"/>
          <g clip-path="url(#fp-clip)">
            <g class="fp-pattern" transform="translate(110, 117)">
              <circle r="4" class="fp-ridge-center"/>
              <ellipse rx="11"  ry="10"  class="fp-ridge"/>
              <ellipse rx="21"  ry="18"  class="fp-ridge"/>
              <ellipse rx="31"  ry="27"  class="fp-ridge"/>
              <ellipse rx="41"  ry="36"  class="fp-ridge"/>
              <ellipse rx="51"  ry="45"  class="fp-ridge"/>
              <ellipse rx="61"  ry="54"  class="fp-ridge"/>
              <ellipse rx="71"  ry="63"  class="fp-ridge"/>
              <ellipse rx="82"  ry="73"  class="fp-ridge"/>
              <ellipse rx="93"  ry="84"  class="fp-ridge"/>
              <ellipse rx="105" ry="96"  class="fp-ridge"/>
            </g>
            <rect class="fp-scanline" x="28" y="0" width="164" height="36" fill="url(#scan-grad)"/>
          </g>
          <path class="fp-checkmark" d="M 72 117 L 97 144 L 148 88" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="28" y="222" width="164" height="44" rx="10" class="fp-bottom"/>
          <circle cx="110" cy="244" r="7" class="fp-led"/>
          <text x="126" y="249" class="fp-scan-label">SCAN</text>
        </svg>
        <div class="fp-pulse"></div>
      </div>

      <div class="ss-status-area">
        <div id="status-idle" class="ss-status-block">
          <div class="ss-finger-hint">☝</div>
          <p class="ss-instruction">Coloca tu dedo en el lector<br>para registrar tu entrada</p>
        </div>
        <div id="status-scanning" class="ss-status-block hidden">
          <div class="ss-dots"><span></span><span></span><span></span></div>
          <p class="ss-scan-text">Leyendo huella dactilar...</p>
        </div>
        <div id="status-success" class="ss-status-block hidden">
          <div class="ss-result-icon ss-icon-success">✓</div>
          <div class="ss-result-name" id="member-name-display"></div>
          <div class="ss-result-sub ss-sub-success">
            Acceso permitido &nbsp;·&nbsp; <span id="access-time"></span>
          </div>
        </div>
        <div id="status-error" class="ss-status-block hidden">
          <div class="ss-result-icon ss-icon-error">✕</div>
          <div class="ss-result-title ss-title-error">Huella no reconocida</div>
          <div class="ss-result-sub ss-sub-error">Por favor, coloca tu dedo nuevamente</div>
        </div>
        <div id="status-expired" class="ss-status-block hidden">
          <div class="ss-result-icon ss-icon-expired">⚠</div>
          <div class="ss-result-member" id="member-expired-display"></div>
          <div class="ss-result-title ss-title-expired">Suscripción Vencida</div>
          <div class="ss-result-sub ss-sub-expired">Dirígete a recepción para renovar tu membresía</div>
        </div>
      </div>
    </div>

    <!-- COLUMNA DERECHA: imagen configurable -->
    <div class="ss-col-featured">
      <div class="ss-featured-frame" id="ss-featured-frame">
        <img id="ss-featured-img" class="ss-featured-img" src="" alt="Imagen destacada" style="display:none">
        <div class="ss-featured-placeholder" id="ss-featured-placeholder">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="0.9" stroke-dasharray="3 2" opacity="0.35"/>
            <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" opacity="0.3"/>
            <path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.3"/>
          </svg>
          <span>Imagen configurable</span>
          <a href="/screensaver/carousel-admin">Cambiar desde admin</a>
        </div>
      </div>
    </div>

  </main>

  <!-- CARRUSEL DE PROMOCIONES -->
  <div class="ss-carousel-section">
    <div class="ss-carousel-header">Promociones &amp; Productos</div>
    <div class="ss-carousel-wrapper">
      <div id="ss-carousel-track" class="ss-carousel-track"></div>
      <div id="ss-carousel-empty" class="ss-carousel-empty hidden">
        Sin imágenes · <a href="/screensaver/carousel-admin">Agregar desde el panel admin</a>
      </div>
    </div>
    <div id="ss-carousel-dots" class="ss-carousel-dots"></div>
  </div>

  <script src="/js/screensaver.js"></script>
</body>
</html>
