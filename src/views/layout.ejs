<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' · Gimnasio' : 'Gimnasio' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">🏋️ Gimnasio</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/members">Socios</a></li>
          <li class="nav-item"><a class="nav-link" href="/plans">Planes</a></li>
          <li class="nav-item"><a class="nav-link" href="/checkin">Check-in</a></li>
          <li class="nav-item"><a class="nav-link" href="/stats">Estadísticas</a></li>
        </ul>
        <form action="/logout" method="POST" class="d-flex">
          <button class="btn btn-outline-light btn-sm" type="submit">Cerrar sesión</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container pb-5">
    <%- body %>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
