<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' · Panther Zone Gym' : 'Panther Zone Gym' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid" style="max-width:1200px;margin:auto">
      <a class="navbar-brand" href="/">
        <img src="/img/logo.png" alt="Logo">
        <span class="brand-name">Panther <span class="brand-accent">Zone</span> Gym</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav me-auto ms-3 gap-1">
          <li class="nav-item"><a class="nav-link" href="/">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/members">Socios</a></li>
          <% if (admin && admin.role === 'admin') { %>
          <li class="nav-item"><a class="nav-link" href="/plans">Planes</a></li>
          <% } %>
          <li class="nav-item"><a class="nav-link" href="/checkin">Check-in</a></li>
          <% if (admin && admin.role === 'admin') { %>
          <li class="nav-item"><a class="nav-link" href="/stats">Estadísticas</a></li>
          <li class="nav-item"><a class="nav-link" href="/screensaver/carousel-admin">Carrusel</a></li>
          <% } %>
        </ul>
        <form action="/logout" method="POST" class="d-flex">
          <button class="btn btn-outline-light btn-sm" type="submit">Cerrar sesión</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container pb-5">
    <%- body %>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Marcar nav link activo según la ruta actual
    (function () {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(link => {
        const href = link.getAttribute('href');
        const isActive = href === '/'
          ? path === '/'
          : path.startsWith(href);
        if (isActive) link.classList.add('active');
      });
    })();
  </script>
</body>
</html>
